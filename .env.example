# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=orc_session
SESSION_TTL_DAYS=30

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=openradio
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openradio?schema=public

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Streaming ─────────────────────────────────────────────────────────
# Public URL listeners use to reach Icecast (via nginx proxy on :8080)
STREAM_PUBLIC_BASE_URL=http://localhost:8080
# Optional HLS base URL for mobile-friendly playback, e.g. https://openradio.iraady.com/api/hls
STREAM_HLS_BASE_URL=
# Internal hostname of the Icecast container (used by the app + Liquidsoap)
STREAM_SOURCE_HOST=icecast
ICECAST_SOURCE_PORT=8000
# Port nginx exposes the geo-blocked Icecast proxy on
STREAM_PORT=8080

# ── Icecast ───────────────────────────────────────────────────────────
ICECAST_PORT=8000
ICECAST_HOSTNAME=icecast
ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_ADMIN_PASSWORD=change-me-admin
ICECAST_RELAY_PASSWORD=change-me-relay
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_EMAIL=admin@openradio.local

# ── Liquidsoap AutoDJ ─────────────────────────────────────────────────
LIQ_ICECAST_HOST=icecast
LIQ_ICECAST_PORT=8000
LIQ_ICECAST_PASSWORD=change-me-source
LIQ_APP_BASE_URL=http://app:3000

# ── Security ──────────────────────────────────────────────────────────
# Secret used to authenticate internal cron API calls
METRICS_POLL_SECRET=change-me-secret

# ── File Storage ──────────────────────────────────────────────────────
# Directory where uploaded audio files are stored (Docker volume path)
UPLOAD_DIR=/app/uploads
# Max audio file upload size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800

# ── Config Directories (populated at runtime by the app) ─────────────
# Per-station Liquidsoap .liq scripts (shared with Liquidsoap container)
LIQ_CONFIG_DIR=/app/liquidsoap-configs
# Per-station nginx geo-block .conf snippets (shared with nginx container)
NGINX_GEO_DIR=/app/nginx-geo
# Per-station Icecast ACL XML fragments
ICECAST_ACL_DIR=/app/icecast-acl

# ── Email (for password reset) ────────────────────────────────────────
# Set these to enable email delivery. Leave blank to log reset links to stdout.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openradio.local
