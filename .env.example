# App
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=orc_session
SESSION_TTL_DAYS=30

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=openradio
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openradio?schema=public

# Redis (optional for future workers/queues)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Streaming URL construction used by the app
STREAM_PUBLIC_BASE_URL=http://localhost:8000
STREAM_SOURCE_HOST=icecast
ICECAST_SOURCE_PORT=8000

# Icecast
ICECAST_PORT=8000
ICECAST_HOSTNAME=icecast
ICECAST_SOURCE_PASSWORD=sourcepass
ICECAST_ADMIN_PASSWORD=adminpass
ICECAST_RELAY_PASSWORD=relaypass
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_EMAIL=admin@openradio.local

# Liquidsoap AutoDJ
LIQ_ICECAST_HOST=icecast
LIQ_ICECAST_PORT=8000
LIQ_ICECAST_PASSWORD=sourcepass
LIQ_STREAM_MOUNT=/demo.mp3
LIQ_STREAM_NAME=OpenRadio Demo
LIQ_STREAM_DESCRIPTION=Baseline AutoDJ stream
LIQ_STREAM_GENRE=Mixed
LIQ_STREAM_URL=http://localhost:3000
